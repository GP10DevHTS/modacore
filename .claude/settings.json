{
  "permissions": {
    "allow": [
      "PowerShell(php artisan route:list *)",
      "PowerShell(php artisan migrate:status *)",
      "PowerShell(php artisan config:show *)",
      "PowerShell(php artisan list *)",
      "PowerShell(php artisan test --compact *)",
      "PowerShell(php artisan test --compact --filter=*)",
